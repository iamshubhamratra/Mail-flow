# ============================================================================
# MailFlow — Environment Variables
# Copy to `.env` at the repo root. NEVER commit `.env`.
# Both apps/web and apps/worker read from this single root `.env`.
# ============================================================================

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug
# Public base URL of the web app (used for tracking links, OAuth callbacks, webhooks)
APP_URL=http://localhost:3000

# --- Database (MongoDB Atlas) ----------------------------------------------
# Create a free cluster at https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/mailflow?retryWrites=true&w=majority

# --- Cache + Queue (Redis / Upstash) ---------------------------------------
# Upstash: https://console.upstash.com → create Redis DB → copy the rediss:// URL.
# BullMQ requires a TCP Redis connection (use the "Redis" connection string, not REST).
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# --- Auth.js v5 (NextAuth) -------------------------------------------------
# Generate: `openssl rand -base64 32`  (or `npx auth secret`)
AUTH_SECRET=replace-with-32-byte-random-base64
AUTH_URL=http://localhost:3000
# Google OAuth — https://console.cloud.google.com → Credentials → OAuth client (Web)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Encryption (AES-256-GCM for stored email-account tokens/passwords) ----
# MUST be 32 bytes, base64-encoded. Generate: `openssl rand -base64 32`
ENCRYPTION_KEY=replace-with-32-byte-random-base64

# --- Transactional email (optional) ----------------------------------------
# Used to send account-verification emails. When unset, the verification link
# is written to the server log instead (fine for local dev).
# nodemailer connection URL, e.g. smtp://user:pass@smtp.host.com:587
SYSTEM_SMTP_URL=
SYSTEM_EMAIL_FROM="MailFlow <noreply@yourdomain.com>"

# --- AI (OpenRouter) -------------------------------------------------------
# Single key routes to Claude / GPT / Gemini per task. https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- Gmail Push (Google Cloud Pub/Sub) -------------------------------------
# Topic the Gmail watch publishes to; push subscription targets /api/webhooks/gmail
GMAIL_PUBSUB_TOPIC=projects/<gcp-project>/topics/mailflow-gmail
# Shared token verified on inbound Pub/Sub push requests
GMAIL_PUBSUB_VERIFICATION_TOKEN=replace-with-random-token

# --- Worker ----------------------------------------------------------------
# Port the worker's health server listens on (GET /health).
HEALTH_PORT=8080

# --- Observability (optional) ----------------------------------------------
SENTRY_DSN=
