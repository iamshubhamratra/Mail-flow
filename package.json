{
  "name": "mailflow",
  "version": "0.1.0",
  "private": true,
  "description": "MailFlow — AI-powered multi-account email outreach & automation SaaS",
  "packageManager": "pnpm@10.18.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@mailflow/web",
    "dev:worker": "turbo run dev --filter=@mailflow/worker",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@mailflow/db": "workspace:*",
    "@mailflow/email": "workspace:*",
    "@mailflow/queue": "workspace:*",
    "@mailflow/shared": "workspace:*",
    "@types/node": "^22.10.5",
    "mongodb-memory-server": "^11.1.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
